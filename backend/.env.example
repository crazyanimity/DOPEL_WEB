# Copy this file to ".env" and fill in real values. NEVER commit the real ".env" file.

# Postgres connection
# Railway: add a Postgres plugin, then copy its DATABASE_URL here.
# Note: if it starts with "postgres://" that's fine — the code auto-converts it.
DATABASE_URL=postgresql://dopel_user:CHANGE_ME@localhost:5432/dopel_db

# Long random string used to sign login sessions (JWTs).
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Long random string used to encrypt stored chat data at rest.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Groq API key for Smart Mode — kept server-side only, never sent to the frontend.
# Get one free at https://console.groq.com
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY

# Comma-separated list of frontend origins allowed to call this API.
# For Railway + Vercel: use your actual Vercel URL(s).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Access token lifetime, in minutes.
JWT_EXPIRE_MINUTES=1440

# Gmail SMTP for sending OTP verification emails.
# If not set, OTPs are printed to the server console (dev mode).
# To set up: enable 2FA on your Google account, then generate an App Password
# at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# OTP expiry in minutes (default: 10)
OTP_EXPIRE_MINUTES=10
